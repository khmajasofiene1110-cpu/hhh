# WalletIQ front controller (PHP router: index.php)
#
# Open the app as http://localhost/<folder>/hhh/ (e.g. /Qwallet/hhh/).
# Do not hardcode RewriteBase here — Apache uses the directory that contains this file.
# If rewrites still fail, uncomment ONE line that matches your URL path:
# RewriteBase /Qwallet/hhh/

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Real files & directories (CSS, JS, public/, …) — serve as-is
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else → front controller (index.php routes)
    RewriteRule ^(.*)$ index.php [L]
</IfModule>
